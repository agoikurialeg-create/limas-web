RewriteEngine On

# ===============================
# QUITAR .html DE LAS URL
# ===============================

# Redirige /pagina.html → /pagina
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# ===============================
# HOME
# ===============================

RewriteRule ^$ app/index.html [L]

# ===============================
# PÁGINAS PRINCIPALES
# ===============================

RewriteRule ^manicura-pedicura/?$ app/manicura-pedicura.html [L]
RewriteRule ^unas-esculpidas/?$ app/unas-esculpidas.html [L]
RewriteRule ^depilacion-cera/?$ app/depilacion-cera.html [L]
RewriteRule ^nuestra-historia/?$ app/nuestra-historia.html [L]

# ===============================
# PÁGINAS LEGALES
# ===============================

RewriteRule ^aviso-legal/?$ legal/aviso-legal.html [L]
RewriteRule ^privacidad/?$ legal/privacidad.html [L]
RewriteRule ^cookies/?$ legal/cookies.html [L]

# ===============================
# SEGURIDAD BÁSICA
# ===============================

Options -Indexes